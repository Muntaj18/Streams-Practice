//Sort numbers by number of digits

import java.util.*;
import java.util.stream.*;
class Main {
    public static void main(String[] args) {
       
        List<Integer> list = List.of(5, 123, 9, 45, 1000, 12);
        List<Integer> result=
        list.stream()
        .sorted(Comparator.comparing(s->String.valueOf(s).length()))
        .toList();
        


          System.out.println(result);
    }
}
