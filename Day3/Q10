//From list → return elements whose square is > 50


import java.util.*;
import java.util.stream.*;
class Main {
    public static void main(String[] args) {
         List<Integer> list = List.of(2, 5, 8, 9, 3);
         
         List<Integer> result=
         list.stream()
         .filter(n->n*n>50)
         .toList();


          System.out.println(result);
    }
}
