//From list of integers → return list of cubes of even numbers only

import java.util.*;
import java.util.stream.*;
class Main {
    public static void main(String[] args) {
        List<Integer> list = List.of(1, 2, 3, 4, 5, 6);
        
        List<Integer> result=
        list.stream()
        .filter(n->n%2==0)
        .map(n->n*n*n)
        .toList();
        
      
          System.out.println(result);
      
        


    }
}
