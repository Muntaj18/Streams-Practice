//Sum of squares of odd numbers

import java.util.*;
import java.util.stream.*;
class Main {
    public static void main(String[] args) {
        List<Integer> numbers = List.of(1, 2, 3, 4, 5);
        
       int result=
       numbers.stream()
       .filter(n->n%2!=0)
       .map(n->n*n)
       .reduce(0,Integer::sum);
      
       
          System.out.println(result);
    }
}
