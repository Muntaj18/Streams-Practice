class Solution {
    public double findMaxAverage(int[] nums, int k) {


        int sum=0;

        for(int i=0;i<k;i++)
        {
            sum=sum+nums[i];
        }
        int avg=sum;
        

        for(int i=k;i<nums.length;i++)
        {
            sum=sum+nums[i];
            sum=sum-nums[i-k];
            avg=Math.max(sum,avg);
        }
        return (double)avg/k;
        
    }
}
